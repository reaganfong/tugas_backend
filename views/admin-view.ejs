<script>
    // ===== SCROLL KE SECTION =====
    function scrollToSection(id) {
        const el = document.getElementById('section-' + id.replace('-container', ''));
        if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    // ===== MARK ALL NOTIFICATIONS =====
    async function markAllNotifikasiRead() {
        try {
            const notifs = await apiService.getNotifikasiDarurat();
            for (const n of notifs) {
                await apiService.markNotifikasiRead(n.id_notif);
            }
            showToast('Semua notifikasi ditandai sudah dibaca!', 'success');
            loadNotifikasi();
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
        }
    }

    // ===== AUTH CHECK =====
    document.addEventListener('DOMContentLoaded', function() {
        var username = localStorage.getItem('username') || 'Admin';
        document.getElementById('namaUser').innerText = username;
        
        document.getElementById('logoutBtn').onclick = function() {
            if (typeof utils !== 'undefined' && utils.logout) { utils.logout(); } else { localStorage.clear(); window.location.href = '/login'; }
        };
    });
</script>

<!-- ==================== DARK MODE TOGGLE ==================== -->
<script>
    (function() {
        const html = document.documentElement;
        const btn = document.getElementById('themeToggle');
        if (!btn) return;
        const icon = btn.querySelector('i');
        const text = btn.querySelector('span');

        function setTheme(isDark) {
            html.setAttribute('data-theme', isDark ? 'dark' : 'light');
            localStorage.setItem('darkMode', isDark ? '1' : '0');
            if (icon && text) {
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
                text.textContent = isDark ? 'Light' : 'Dark';
            }
        }

        // Inisialisasi dari localStorage (sinkron dengan flash script)
        const saved = localStorage.getItem('darkMode') === '1';
        setTheme(saved);

        btn.addEventListener('click', function() {
            const isDark = html.getAttribute('data-theme') === 'dark';
            setTheme(!isDark);
        });
    })();
</script>

