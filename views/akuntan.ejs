<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Akuntan</title>
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        /* ... semua CSS dari file asli ... */
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1><i class="fas fa-calculator"></i> Dashboard Akuntan</h1>
        <div style="display: flex; align-items: center; gap: 12px;">
            <button id="themeToggle" class="btn-theme">
                <i class="fas fa-moon"></i> <span>Dark</span>
            </button>
            <button id="logoutBtn" class="btn-logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </div>
    </div>

    <div class="welcome-text">
        <i class="fas fa-user-circle"></i> Selamat datang, <b id="namaUser"><%= username %></b>
    </div>

    <div class="card">
        <div class="flex-between">
            <h2><i class="fas fa-receipt"></i> Tagihan Pasien</h2>
            <div>
                <button id="addPaymentBtn" class="btn-primary">
                    <i class="fas fa-plus-circle"></i> Tagihan Baru
                </button>
            </div>
        </div>
        
        <!-- ===== NOTIFICATION CONTAINER UNTUK TAGIHAN ===== -->
        <div id="notificationTagihan" class="notification-container"></div>
        
        <div class="filter-bar">
            <label>
                <i class="fas fa-filter"></i> Filter Status:
                <select id="filterStatus">
                    <option value="belum">Belum Lunas</option>
                    <option value="lunas">Lunas</option>
                    <option value="">Semua</option>
                </select>
            </label>
        </div>
        <div id="tagihan-container">
            <i class="fas fa-spinner fa-spin"></i> Memuat...
        </div>
    </div>
    
    <div class="card">
        <h2><i class="fas fa-building"></i> Fasilitas</h2>
        
        <!-- ===== NOTIFICATION CONTAINER UNTUK FASILITAS ===== -->
        <div id="notificationFasilitas" class="notification-container"></div>
        
        <div id="fasilitas-container">
            <i class="fas fa-spinner fa-spin"></i> Memuat...
        </div>
    </div>

    <div class="card">
        <h2><i class="fas fa-clock"></i> Riwayat Check-in / Check-out Pasien</h2>
        <div id="checkinout-container">
            <i class="fas fa-spinner fa-spin"></i> Memuat...
        </div>
    </div>
</div>

<script src="/models/apiService.js"></script>
<script src="/js/utils.js"></script>
<script src="/controllers/dashboardAkuntanController.js"></script>

<script>
    // ==================== DARK MODE ====================
    (function() {
        const html = document.documentElement;
        const toggleBtn = document.getElementById('themeToggle');
        const icon = toggleBtn?.querySelector('i');
        const text = toggleBtn?.querySelector('span');

        function setTheme(theme) {
            html.setAttribute('data-theme', theme);
            localStorage.setItem('rumahsehat_theme', theme);
            if (icon && text) {
                if (theme === 'dark') {
                    icon.className = 'fas fa-sun';
                    text.textContent = 'Light';
                } else {
                    icon.className = 'fas fa-moon';
                    text.textContent = 'Dark';
                }
            }
        }

        // Inisialisasi dari localStorage
        const saved = localStorage.getItem('rumahsehat_theme') || 'light';
        setTheme(saved);

        // Toggle klik
        toggleBtn?.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            setTheme(current === 'dark' ? 'light' : 'dark');
        });
    })();

    // ==================== AUTH CHECK ====================
    document.addEventListener('DOMContentLoaded', function() {
        var username = localStorage.getItem('username') || 'Akuntan';

        var namaUser = document.getElementById('namaUser');
        if (namaUser) {
            namaUser.innerText = username;
        }

        var logoutBtn = document.getElementById('logoutBtn');
        if (logoutBtn) {
            logoutBtn.onclick = function() {
                try { if (typeof utils !== 'undefined' && utils.logout) { utils.logout(); return; } } catch(e) {}
                localStorage.clear();
                window.location.href = '/login';
            };
        }
    });
</script>

</body>
</html>