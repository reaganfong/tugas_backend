# Environment variables for Rumah Sehat Backend
# Copy this file to .env and fill in the values

PORT=3000
# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/rumahsehat?retryWrites=true&w=majority"
JWT_SECRET='your_jwt_secret_here'